{
  "version": 2,
  "routes": [
    { "src": "/api/search", "dest": "/api/search.py" },
    { "src": "/api/lyrics", "dest": "/api/lyrics.py" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*\\.(css|js|png|jpg|jpeg|gif|ico|json|webmanifest|svg))", "dest": "/public/$1" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
